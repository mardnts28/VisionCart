<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    android:fitsSystemWindows="true">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <!--            HEADER              -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/logoContainer"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="?attr/appPrimaryColor"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_eye"
                            android:tint="?attr/appBackgroundColor"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VISION CART"
                            android:textColor="?attr/appPrimaryColor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Grocery Assistant"
                            android:textColor="?attr/appTextSecondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Mic Button -->
                <FrameLayout
                    android:id="@+id/btnMic"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_dark_rounded"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic"
                        android:tint="?attr/appTextColor"/>
                </FrameLayout>

            </RelativeLayout>


            <!--         WELCOME CARD           -->
            <LinearLayout
                android:id="@+id/welcomeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_welcome_card"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_circle_dark"
                    android:layout_marginEnd="12dp"
                    android:layout_gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_volume"
                        android:tint="?attr/appPrimaryColor"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good day! Ready to shop?"
                        android:textColor="?attr/appPrimaryColor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='Tap "Scan Product" to identify any grocery item instantly.'
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>


            <!--       SCAN PRODUCT BUTTON      -->
            <LinearLayout
                android:id="@+id/btnScanProduct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="110dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_yellow_rounded_large"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_scan"
                    android:tint="?attr/appBackgroundColor"/>
 
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCAN PRODUCT"
                    android:textColor="?attr/appBackgroundColor"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
 
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to open camera scanner"
                    android:textColor="?attr/appBackgroundColor"
                    android:textSize="12sp"
                    android:alpha="0.8"/>
            </LinearLayout>


            <!--   HISTORY + ACCESSIBILITY      -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="85dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_dark_rounded"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_history"
                        android:tint="?attr/appPrimaryColor"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="History"
                        android:textColor="?attr/appTextColor"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
 
                <LinearLayout
                    android:id="@+id/btnAccessibility"
                    android:layout_width="0dp"
                    android:layout_height="85dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_dark_rounded"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_thunder"
                        android:tint="?attr/appPrimaryColor"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility"
                        android:textColor="?attr/appTextColor"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>


            <!--          QUICK GUIDE           -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUICK GUIDE"
                android:textColor="@color/text_gray"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <!-- Guide Item 1 — Point Camera -->
            <RelativeLayout
                android:id="@+id/guidePointCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="1dp">

                <FrameLayout
                    android:id="@+id/badge1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_nav_active"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="1"
                        android:textColor="?attr/appBackgroundColor"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/badge1"
                    android:layout_toStartOf="@+id/arrow1"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Point Camera"
                        android:textColor="?attr/appTextColor"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hold your phone toward the product barcode"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/arrow1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="›"
                    android:textColor="@color/text_gray"
                    android:textSize="20sp"/>
            </RelativeLayout>

            <!-- Guide Item 2 — Auto-Detect -->
            <RelativeLayout
                android:id="@+id/guideAutoDetect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="1dp">

                <FrameLayout
                    android:id="@+id/badge2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_nav_active"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="2"
                        android:textColor="?attr/appBackgroundColor"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/badge2"
                    android:layout_toStartOf="@+id/arrow2"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-Detect"
                        android:textColor="?attr/appTextColor"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App finds and scans the barcode automatically"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/arrow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="›"
                    android:textColor="@color/text_gray"
                    android:textSize="20sp"/>
            </RelativeLayout>


            <!--  Guide Item 3 — Hear Info   -->

            <RelativeLayout
                android:id="@+id/guideHearInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/badge3"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_nav_active"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textColor="?attr/appBackgroundColor"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/badge3"
                    android:layout_toStartOf="@+id/arrow3"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:id="@+id/tvReadAloudTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="READ ALOUD"
                        android:textColor="?attr/appTextColor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>
                    <TextView
                        android:id="@+id/tvReadAloudSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hear all product information"
                        android:textColor="?attr/appTextSecondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/arrow3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="›"
                    android:textColor="@color/text_gray"
                    android:textSize="20sp"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>


    <!-- VOICE ASSISTANT CARD  -->
    <RelativeLayout
        android:id="@+id/voiceAssistantCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomNav"
        android:layout_alignParentBottom="false"
        android:background="@drawable/bg_voice_card"
        android:padding="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- Speaker icon with yellow background -->
        <FrameLayout
            android:id="@+id/voiceIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_yellow_rounded"
            android:layout_centerVertical="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_volume"
                android:tint="?attr/appPrimaryColor"/>
        </FrameLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/voiceIcon"
            android:layout_toStartOf="@+id/btnCloseVoice"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOICE ASSISTANT"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice assistant is active and ready to help."
                android:textColor="?attr/appTextColor"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnCloseVoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="✕"
            android:textColor="@color/text_gray"
            android:textSize="16sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </RelativeLayout>


    <!--           BOTTOM NAVIGATION            -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="?attr/appNavColor"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_nav_active">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home"
                    android:tint="?attr/appBackgroundColor"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navScan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_scan"
                android:tint="?attr/appPrimaryColor"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>