<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:background="@drawable/bg_dark_rounded"
    android:layout_marginBottom="10dp"
    android:padding="10dp">


    <!--        PRODUCT IMAGE            -->
    <ImageView
        android:id="@+id/ivProductImage"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_dark_rounded"
        android:src="@drawable/ic_logo"/>

    <!--        ACTION BUTTONS           -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Speaker Button — theme-aware background -->
        <FrameLayout
            android:id="@+id/btnSpeak"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_speaker_button"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="5dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_volume"
                android:tint="?attr/appPrimaryColor"/>
        </FrameLayout>

        <!-- Arrow Button — theme-aware tint -->
        <FrameLayout
            android:id="@+id/btnDetail"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_dark_rounded"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_go"
                android:tint="?attr/appTextColor"/>
        </FrameLayout>

    </LinearLayout>


    <!--        PRODUCT INFO             -->
    <LinearLayout
        android:id="@+id/productInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/ivProductImage"
        android:layout_toStartOf="@id/actionButtons"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <!-- Brand -->
        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextSecondary"
            android:textSize="11sp"/>

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/appTextColor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <!-- Price + Time row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <!-- Price -->
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/appPrimaryColor"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>


            <ImageView
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_history"
                android:tint="?attr/appTextSecondary"
                android:layout_marginEnd="3dp"/>

            <!-- Time -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/appTextSecondary"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"/>

            <!-- Star Indicator -->
            <ImageView
                android:id="@+id/ivItemStarred"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_star"
                android:tint="?attr/appPrimaryColor"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>