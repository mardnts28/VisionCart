<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackgroundColor"
    android:fitsSystemWindows="true">


    <!--              TOP HEADER BAR             -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_alignParentTop="true"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp">

        <!-- Back Button - increased to 60dp -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@drawable/bg_dark_rounded"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:tint="?attr/appTextColor"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Product Details"
            android:textColor="?attr/appTextColor"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- Star Button -->
        <FrameLayout
            android:id="@+id/btnStar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnScanAgain"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_dark_rounded"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ivStar"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_star"
                android:tint="?attr/appTextSecondary"/>
        </FrameLayout>

        <!-- Scan Again Button - increased to 60dp -->
        <FrameLayout
            android:id="@+id/btnScanAgain"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_dark_rounded"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_scan"
                android:tint="?attr/appTextColor"/>
        </FrameLayout>

    </RelativeLayout>

    <!--           BOTTOM NAVIGATION - increased height  -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="?attr/appNavColor"
        android:orientation="horizontal">


        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navScan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_scan"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="?attr/appTextSecondary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="?attr/appTextSecondary"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>


    <!--           SCROLLABLE CONTENT            -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!--        PRODUCT IMAGE BANNER     -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="?attr/appCardColor">

                <!-- Product Image -->
                <ImageView
                    android:id="@+id/ivProductBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_logo"/>

                <!-- Category Badge -->
                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_margin="12dp"
                    android:text="Canned Goods"
                    android:textColor="?attr/appBackgroundColor"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_nav_active"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"/>

            </RelativeLayout>


            <!--        PRODUCT NAME + BRAND     -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Campbell's"
                    android:textColor="?attr/appTextSecondary"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomato Soup"
                    android:textColor="?attr/appTextColor"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <!-- Health Rating Badge -->
                <LinearLayout
                    android:id="@+id/cardHealthRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_category_badge"
                    android:backgroundTint="#FF9800"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/tvHealthRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate"
                        android:textColor="?attr/appBackgroundColor"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>


            </LinearLayout>

            <!--        INFO CARDS 2x2 GRID      -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <!-- Row 1: Price + Expires -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/btnEditPrice"
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_price_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_peso"
                                    android:tint="?attr/appPrimaryColor"
                                    android:layout_marginEnd="4dp"
                                    android:layout_gravity="center_vertical"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PRICE"
                                    android:textColor="@color/text_gray"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.1"/>
                            </LinearLayout>
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_alignParentEnd="true"
                                android:src="@drawable/ic_settings"
                                android:tint="@color/text_gray"
                                android:alpha="0.6"/>
                        </RelativeLayout>
                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱ 85.00"
                            android:textColor="?attr/appPrimaryColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Expires Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_expires_card"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_calendar"
                                android:tint="?attr/appPrimaryColor"
                                android:layout_marginEnd="4dp"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EXPIRES"
                                android:textColor="?attr/appTextSecondary"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvExpires"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="December 2025"
                            android:textColor="?attr/appPrimaryColor"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Weight + Barcode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Weight Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_weight_card"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_box"
                                android:tint="?attr/appPrimaryColor"
                                android:layout_marginEnd="4dp"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WEIGHT"
                                android:textColor="?attr/appTextSecondary"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="305g"
                            android:textColor="?attr/appPrimaryColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Barcode Card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_dark_rounded"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_scan"
                                android:tint="@color/text_gray"
                                android:layout_marginEnd="4dp"
                                android:layout_gravity="center_vertical"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BARCODE"
                                android:textColor="@color/text_gray"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvBarcode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="051000012722"
                            android:textColor="?attr/appTextColor"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>


            <!--         READ ALOUD BUTTON       -->
            <LinearLayout
                android:id="@+id/btnReadAloud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_read_aloud_btn"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivReadAloudIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_volume"
                    android:tint="@color/text_white"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvReadAloudTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="READ ALOUD"
                        android:textColor="?attr/appBackgroundColor"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>
                    <TextView
                        android:id="@+id/tvReadAloudSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hear all product information"
                        android:textColor="?attr/appBackgroundColor"
                        android:alpha="0.8"
                        android:textSize="11sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!--          INGREDIENTS            -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INGREDIENTS"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tomato Puree (Water, Tomato Paste), High Fructose Corn Syrup, Salt, Potassium Chloride, Natural Flavoring, Citric Acid, Ascorbic Acid (Vitamin C)."
                    android:textColor="?attr/appTextColor"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>
            <!-- ─────────────────────────────── -->
            <!--       ALLERGEN WARNING          -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:id="@+id/allergenCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#33FF4444" 
                android:orientation="horizontal"
                android:padding="14dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <!-- Warning icon — replace ic_logo with your warning/alert icon -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_logo"
                    android:tint="#FF6633"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALLERGEN WARNING"
                        android:textColor="#FF6633"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvAllergens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contains Wheat. Made in a facility that processes Tree Nuts."
                        android:textColor="?attr/appTextColor"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>
            </LinearLayout>

            <!--        NUTRITIONAL FACTS        -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <!-- Section Header -->
                <RelativeLayout
                    android:id="@+id/nutritionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_centerVertical="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_star"
                            android:tint="?attr/appPrimaryColor"
                            android:layout_marginEnd="8dp"
                            android:layout_gravity="center_vertical"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NUTRITIONAL FACTS"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:letterSpacing="0.12"
                            android:layout_gravity="center_vertical"/>
                    </LinearLayout>

                    <!-- Expand/Collapse arrow -->
                    <TextView
                        android:id="@+id/tvNutritionArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="∧"
                        android:textColor="@color/text_gray"
                        android:textSize="16sp"/>

                </RelativeLayout>

                <!-- Nutrition Rows -->
                <LinearLayout
                    android:id="@+id/nutritionContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp">

                    <!-- Calories -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Calories"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="90 kcal"
                            android:textColor="#FFAA33"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                    <!-- Total Fat -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Total Fat"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="0g"
                            android:textColor="#FF6666"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                    <!-- Sodium -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Sodium"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="480mg"
                            android:textColor="#BB88FF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                    <!-- Total Carbs -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Total Carbs"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="20g"
                            android:textColor="#44AAFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                    <!-- Sugars -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Sugars"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="12g"
                            android:textColor="#FF88BB"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF"/>

                    <!-- Protein -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Protein"
                            android:textColor="?attr/appTextColor"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="2g"
                            android:textColor="#44DD88"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!--        GEMINI AI Q&A CARD       -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_rounded"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_logo"
                        android:tint="#AA66FF"
                        android:layout_marginEnd="8dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ASK GEMINI"
                            android:textColor="#AA66FF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ask anything about this product"
                            android:textColor="?attr/appTextSecondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Search row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etQuestion"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_search_input"
                        android:hint="e.g. Is this safe for diabetics?"
                        android:textColor="?attr/appTextColor"
                        android:textColorHint="@color/text_gray"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"/>

                    <FrameLayout
                        android:id="@+id/btnAskGemini"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_yellow_rounded"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivAskIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_search"
                            android:tint="?attr/appBackgroundColor"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- Loading indicator -->
                <LinearLayout
                    android:id="@+id/geminiLoadingRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp">
                    <ProgressBar
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:indeterminateTint="#AA66FF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gemini is thinking..."
                        android:textColor="#AA66FF"
                        android:textSize="13sp"
                        android:textStyle="italic"/>
                </LinearLayout>

                <!-- AI Response Card -->
                <LinearLayout
                    android:id="@+id/geminiResponseCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="14dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="GEMINI SAYS"
                            android:textColor="#AA66FF"
                            android:textSize="10sp"
                            android:letterSpacing="0.15"
                            android:textStyle="bold"/>
                        <ImageView
                            android:id="@+id/btnSpeakAnswer"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_volume"
                            android:tint="?attr/appPrimaryColor"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAiResponse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="?attr/appTextColor"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.5"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <RelativeLayout
                android:id="@+id/voiceReadingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_voice_card"
                android:padding="14dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/voiceReadIconBg"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_nav_active"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_peso"
                        android:tint="?attr/appBackgroundColor"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/voiceReadIconBg"
                    android:layout_toStartOf="@+id/btnCloseReading"
                    android:layout_centerVertical="true"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOICE ASSISTANT"
                        android:textColor="?attr/appPrimaryColor"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvVoiceReadingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product: Tomato Soup by Campbell's. Price: ₱ 85.00..."
                        android:textColor="?attr/appTextColor"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:lineSpacingMultiplier="1.4"
                        android:maxLines="5"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnCloseReading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:text="✕"
                    android:textColor="@color/text_gray"
                    android:textSize="16sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>