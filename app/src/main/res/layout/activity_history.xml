<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">


    <!--              TOP HEADER BAR             -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp">

        <!-- History Icon + Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_history"
                android:tint="@color/yellow_primary"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan History"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"/>
        </LinearLayout>

        <!-- Clear Button  -->
        <LinearLayout
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_clear_button_red"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_delete"
                android:tint="#FF4444"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textColor="#FF4444"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </RelativeLayout>


    <!--           BOTTOM NAVIGATION             -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:background="@color/nav_bg"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:tint="@color/text_gray"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/text_gray"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navScan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_scan"
                android:tint="@color/text_gray"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textColor="@color/text_gray"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_yellow_rounded">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_history"
                    android:tint="@color/bg_dark"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textColor="@color/yellow_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/text_gray"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/text_gray"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>


    <!--           MAIN CONTENT AREA             -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottomNav">


        <!--     EMPTY STATE (no history yet)    -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Box/Package icon background -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_empty_icon"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_box"
                    android:tint="#666677"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Scanned Products"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:text="Products you scan will appear here so you can review them later."
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_gravity="center"
                android:layout_marginBottom="28dp"/>

            <!-- Scan First Product Button -->
            <LinearLayout
                android:id="@+id/btnScanFirst"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_scan_button"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan First Product"
                    android:textColor="@color/bg_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>


        <!--   FILLED STATE (has scan history)   -->
        <LinearLayout
            android:id="@+id/filledState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Item count label -->
            <TextView
                android:id="@+id/tvItemCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 product scanned recently"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"/>

            <!-- Scrollable list of scanned items -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/historyList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <!--   SAMPLE HISTORY ITEM   -->
                    <RelativeLayout
                        android:id="@+id/sampleHistoryItem"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_dark_rounded"
                        android:layout_marginBottom="10dp"
                        android:padding="10dp">

                        <!-- Product Image -->
                        <ImageView
                            android:id="@+id/ivProductImage"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_centerVertical="true"
                            android:layout_alignParentStart="true"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_dark_rounded"
                            android:src="@drawable/ic_logo"/>

                        <!-- Product Info -->
                        <LinearLayout
                            android:id="@+id/productInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivProductImage"
                            android:layout_toStartOf="@+id/actionButtons"
                            android:layout_centerVertical="true"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:id="@+id/tvBrand"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kellogg's"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvProductName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Original Corn Flakes"
                                android:textColor="@color/text_white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="3dp">

                                <TextView
                                    android:id="@+id/tvPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₱ 132.00"
                                    android:textColor="@color/yellow_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:layout_marginEnd="8dp"/>

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:layout_gravity="center_vertical"
                                    android:src="@drawable/ic_history"
                                    android:tint="@color/text_gray"
                                    android:layout_marginEnd="4dp"/>

                                <TextView
                                    android:id="@+id/tvTime"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Just now"
                                    android:textColor="@color/text_gray"
                                    android:textSize="11sp"
                                    android:layout_gravity="center_vertical"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Action Buttons  -->
                        <LinearLayout
                            android:id="@+id/actionButtons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <!-- Speaker Button -->
                            <FrameLayout
                                android:id="@+id/btnSpeak"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_speaker_button"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginBottom="4dp">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_volume"
                                    android:tint="@color/yellow_primary"/>
                            </FrameLayout>

                            <!-- Arrow Button -->
                            <FrameLayout
                                android:id="@+id/btnDetail"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_dark_rounded"
                                android:clickable="true"
                                android:focusable="true">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_go"
                                    android:tint="@color/text_gray"/>
                            </FrameLayout>

                        </LinearLayout>

                    </RelativeLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>